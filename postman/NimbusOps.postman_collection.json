          "name": "Login as Admin",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/auth/login",
            "description": "Logs in and stores the Sanctum token in the active environment.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{demo_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
